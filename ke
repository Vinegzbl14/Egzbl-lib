    AddStroke(optFrame, Theme.Border, 1)

    local optLayout = Make("UIListLayout",{Padding=UDim.new(0,2),SortOrder=Enum.SortOrder.LayoutOrder}, optFrame)
    Make("UIPadding",{PaddingTop=UDim.new(0,5),PaddingBottom=UDim.new(0,5),PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6)}, optFrame)

    local optBtns = {}
    for i,opt in ipairs(options or {}) do
        local ob = Make("TextButton",{
            Size=UDim2.new(1,0,0,26),
            BackgroundColor3=(opt==selected) and LerpColor(self.Accent,Theme.BgDark,0.7) or Theme.BtnIdle,
            BorderSizePixel=0,Text=opt,
            TextColor3=(opt==selected) and self.Accent or Theme.TextMain,
            TextSize=11,Font=FontSub,AutoButtonColor=false,ZIndex=26,
        }, optFrame)
        AddCorner(ob, 5)
        optBtns[opt] = ob

        ob.MouseButton1Click:Connect(function()
            selected=opt; selLabel.Text=opt; isOpen=false
            for n,b in pairs(optBtns) do
                local isSel=(n==selected)
                QT(b,{BackgroundColor3=isSel and LerpColor(self.Accent,Theme.BgDark,0.7) or Theme.BtnIdle,TextColor3=isSel and self.Accent or Theme.TextMain},0.15):Play()
            end
            QT(optFrame,{Size=UDim2.new(1,0,0,0)},0.2):Play()
            QT(arrow,{Rotation=0},0.2):Play()
            task.delay(0.2, function() optFrame.Visible=false end)
            if callback then callback(opt) end
        end)

        ob.MouseEnter:Connect(function()
            if opt~=selected then QT(ob,{BackgroundColor3=Theme.BtnHover},0.1):Play() end
        end)
        ob.MouseLeave:Connect(function()
            if opt~=selected then QT(ob,{BackgroundColor3=Theme.BtnIdle},0.1):Play() end
        end)
    end

    btn.MouseButton1Click:Connect(function()
        isOpen=not isOpen
        if isOpen then
            optFrame.Visible=true; optFrame.Size=UDim2.new(1,0,0,0)
            local h=optLayout.AbsoluteContentSize.Y+10
            QT(optFrame,{Size=UDim2.new(1,0,0,h)},0.3,Enum.EasingStyle.Quint):Play()
            QT(arrow,{Rotation=180},0.25):Play()
        else
            QT(optFrame,{Size=UDim2.new(1,0,0,0)},0.2):Play()
            QT(arrow,{Rotation=0},0.2):Play()
            task.delay(0.2, function() optFrame.Visible=false end)
        end
    end)

    return self:_AddElement(tabName,{Type="Dropdown",Instance=frame,GetValue=function() return selected end})
end

function CentingUI:AddKeybind(tabName, text, defaultKey, callback)
    local tab = self.Tabs[tabName]
    if not tab then return nil end
    local boundKey = defaultKey or Enum.KeyCode.None
    local listening = false

    local frame = Make("Frame",{Size=UDim2.new(1,0,0,38),BackgroundColor3=Theme.BgElement,BorderSizePixel=0}, tab.Container)
    AddCorner(frame, 8)

    Make("TextLabel",{
        Size=UDim2.new(0.6,0,1,0),Position=UDim2.new(0,14,0,0),
        BackgroundTransparency=1,Text=text or "Keybind",
        TextColor3=Theme.TextMain,TextSize=12,Font=FontMain,TextXAlignment=Enum.TextXAlignment.Left,
    }, frame)

    local keyBox = Make("Frame",{
        Size=UDim2.new(0,76,0,24),Position=UDim2.new(1,-88,0.5,-12),
        BackgroundColor3=Theme.BgInput,BorderSizePixel=0,
    }, frame)
    AddCorner(keyBox, 5)

    local keyLabel = Make("TextLabel",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        Text=boundKey.Name=="None" and "[ ... ]" or "[ "..boundKey.Name.." ]",
        TextColor3=self.Accent,TextSize=10,Font=FontCode,
    }, keyBox)

    local btn = Make("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=10}, frame)
    btn.MouseButton1Click:Connect(function()
        listening=true; keyLabel.Text="[ ... ]"; keyLabel.TextColor3=Theme.Error
    end)

    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if listening and input.UserInputType==Enum.UserInputType.Keyboard then
            boundKey=input.KeyCode
            keyLabel.Text="[ "..boundKey.Name.." ]"
            keyLabel.TextColor3=self.Accent
            listening=false
            if callback then callback(boundKey) end
        end
    end)

    return self:_AddElement(tabName,{Type="Keybind",Instance=frame,GetKey=function() return boundKey end})
end

function CentingUI:AddCheckbox(tabName, text, default, callback)
    local tab = self.Tabs[tabName]
    if not tab then return nil end
    default = default or false
    local state = default

    local frame = Make("Frame",{Size=UDim2.new(1,0,0,32),BackgroundColor3=Theme.BgElement,BorderSizePixel=0}, tab.Container)
    AddCorner(frame, 8)

    local box = Make("Frame",{
        Size=UDim2.new(0,18,0,18),Position=UDim2.new(0,12,0.5,-9),
        BackgroundColor3=state and self.Accent or Theme.ToggleOff,BorderSizePixel=0,
    }, frame)
    AddCorner(box, 4)

    local check = Make("TextLabel",{
        Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,
        Text="✓",TextColor3=Theme.White,TextSize=12,Font=FontMain,
        TextTransparency=state and 0 or 1,
    }, box)

    Make("TextLabel",{
        Size=UDim2.new(1,-42,1,0),Position=UDim2.new(0,38,0,0),
        BackgroundTransparency=1,Text=text or "Checkbox",
        TextColor3=Theme.TextMain,TextSize=12,Font=FontMain,TextXAlignment=Enum.TextXAlignment.Left,
    }, frame)

    local btn = Make("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=10}, frame)
    btn.MouseButton1Click:Connect(function()
        state=not state
        QT(box,{BackgroundColor3=state and self.Accent or Theme.ToggleOff},0.2):Play()
        QT(check,{TextTransparency=state and 0 or 1},0.2):Play()
        if callback then callback(state) end
    end)

    return self:_AddElement(tabName,{Type="Checkbox",Instance=frame,Set=function(v)
        state=v; box.BackgroundColor3=v and self.Accent or Theme.ToggleOff; check.TextTransparency=v and 0 or 1
    end,Get=function() return state end})
end

-- NOTIFICATIONS
function CentingUI:Notify(title, text, type)
    type = type or "info"
    local colors = {info=self.Accent, success=Theme.Success, warning=Theme.Warning, error=Theme.Error}
    local ac = colors[type] or colors.info

    local notif = Make("Frame",{
        Size=UDim2.new(0,280,0,0),Position=UDim2.new(1,-290,1,-10),
        BackgroundColor3=Theme.BgDark,BorderSizePixel=0,ZIndex=100,
    }, self.Gui)
    AddCorner(notif, 10)
    AddStroke(notif, ac, 1)

    Make("Frame",{
        Size=UDim2.new(0,3,0.7,0),Position=UDim2.new(0,6,0.15,0),
        BackgroundColor3=ac,BorderSizePixel=0,
    }, notif)

    Make("TextLabel",{
        Size=UDim2.new(1,-24,0,18),Position=UDim2.new(0,18,0,8),
        BackgroundTransparency=1,Text=title or "Notification",
        TextColor3=ac,TextSize=12,Font=FontMain,TextXAlignment=Enum.TextXAlignment.Left,
    }, notif)

    Make("TextLabel",{
        Size=UDim2.new(1,-24,0,14),Position=UDim2.new(0,18,0,28),
        BackgroundTransparency=1,Text=text or "",
        TextColor3=Theme.TextDim,TextSize=11,Font=FontSub,
        TextXAlignment=Enum.TextXAlignment.Left,TextWrapped=true,
    }, notif)

    QT(notif,{Size=UDim2.new(0,280,0,52)},0.4,Enum.EasingStyle.Back):Play()

    for _,n in ipairs(self.Notifications) do
        local pos=n.Instance.Position
        QT(n.Instance,{Position=UDim2.new(pos.X.Scale,pos.X.Offset,pos.Y.Scale,pos.Y.Offset-60)},0.3):Play()
    end
    table.insert(self.Notifications,{Instance=notif})

    task.delay(3.5, function()
        QT(notif,{BackgroundTransparency=1},0.3):Play()
        QT(notif,{Size=UDim2.new(0,280,0,0)},0.3,Enum.EasingStyle.Quad,Enum.EasingDirection.In):Play()
        task.delay(0.3, function()
            notif:Destroy()
            for i,n in ipairs(self.Notifications) do
                if n.Instance==notif then table.remove(self.Notifications,i); break end
            end
        end)
    end)
    return notif
end

function CentingUI:Destroy()
    if self.Blur then self.Blur:Destroy() end
    if self.Gui then self.Gui:Destroy() end
end

return CentingUI

