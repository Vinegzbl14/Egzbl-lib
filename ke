function CentingUI:AddToggle(tabName, text, default, callback)
    local tab = self.Tabs[tabName]
    if not tab then return nil end
    default = default or false
    local state = default

    local frame = Make("Frame",{Size=UDim2.new(1,0,0,38),BackgroundColor3=Theme.BgElement,BorderSizePixel=0}, tab.Container)
    AddCorner(frame, 8)

    Make("TextLabel",{
        Size=UDim2.new(1,-60,1,0),Position=UDim2.new(0,14,0,0),
        BackgroundTransparency=1,Text=text or "Toggle",
        TextColor3=Theme.TextMain,TextSize=12,Font=FontMain,
        TextXAlignment=Enum.TextXAlignment.Left,
    }, frame)

    local track = Make("Frame",{
        Size=UDim2.new(0,42,0,22),Position=UDim2.new(1,-54,0.5,-11),
        BackgroundColor3=state and self.Accent or Theme.ToggleOff,BorderSizePixel=0,
    }, frame)
    AddCorner(track, 11)

    local circle = Make("Frame",{
        Size=UDim2.new(0,16,0,16),
        Position=state and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8),
        BackgroundColor3=Theme.White,BorderSizePixel=0,
    }, track)
    AddCorner(circle, 8)

    local btn = Make("TextButton",{Size=UDim2.new(1,0,1,0),BackgroundTransparency=1,Text="",ZIndex=10}, frame)

    local function SetState(v)
        state = v
        QT(track,{BackgroundColor3=v and self.Accent or Theme.ToggleOff},0.25):Play()
        QT(circle,{Position=v and UDim2.new(1,-19,0.5,-8) or UDim2.new(0,3,0.5,-8)},0.3,Enum.EasingStyle.Back):Play()
        if callback then callback(v) end
    end

    btn.MouseButton1Click:Connect(function() SetState(not state) end)

    frame.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseMovement then QT(frame,{BackgroundColor3=Theme.BgSurface},0.15):Play() end
    end)
    frame.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseMovement then QT(frame,{BackgroundColor3=Theme.BgElement},0.15):Play() end
    end)

    return self:_AddElement(tabName,{Type="Toggle",Instance=frame,Set=SetState,Get=function() return state end})
end

