function CentingUI:_SetupDrag()
    local dragging, dragInput = false, nil
    local startPos, startPosFrame

    self.TitleBar.InputBegan:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then
            dragging=true
            startPos=input.Position
            startPosFrame=self.Frame.Position
            input.Changed:Connect(function()
                if input.UserInputState==Enum.UserInputState.End then dragging=false end
            end)
        end
    end)

    self.TitleBar.InputChanged:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch then
            dragInput=input
        end
    end)

    UserInputService.InputChanged:Connect(function(input)
        if input==dragInput and dragging then
            local delta=input.Position-startPos
            self.Frame.Position=UDim2.new(
                startPosFrame.X.Scale, startPosFrame.X.Offset+delta.X,
                startPosFrame.Y.Scale, startPosFrame.Y.Offset+delta.Y
            )
        end
    end)
end

function CentingUI:ToggleMinimize()
    self.IsMinimized = not self.IsMinimized
    local target = self.IsMinimized and UDim2.new(0,520,0,42) or UDim2.new(0,520,0,400)
    QT(self.Frame,{Size=target},0.35):Play()
end

function CentingUI:Close()
    self.IsOpen = false
    QT(self.Blur,{Size=0},0.3):Play()
    QT(self.Frame,{Size=UDim2.new(0,520,0,0),BackgroundTransparency=1},0.35,Enum.EasingStyle.Back,Enum.EasingDirection.In):Play()
    task.delay(0.35, function() self.Gui.Enabled=false end)
end

function CentingUI:Open()
    if self.IsOpen then return end
    self.IsOpen = true
    self.Gui.Enabled = true
    self.Frame.Size = UDim2.new(0,520,0,0)
    self.Frame.BackgroundTransparency = 1
    QT(self.Blur,{Size=18},0.4):Play()
    QT(self.Frame,{Size=UDim2.new(0,520,0,400),BackgroundTransparency=0},0.45,Enum.EasingStyle.Back,Enum.EasingDirection.Out):Play()
end

function CentingUI:Toggle()
    if self.IsOpen then self:Close() else self:Open() end
end

function CentingUI:SetToggleKey(keyCode)
    UserInputService.InputBegan:Connect(function(input, processed)
        if processed then return end
        if input.KeyCode==keyCode then self:Toggle() end
    end)
end

