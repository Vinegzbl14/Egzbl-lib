    self.Blur = Make("BlurEffect",{Size=0,Name="UIBlur"}, Lighting)

    self.Frame = Make("Frame",{
        Name="Main", Size=UDim2.new(0,520,0,400),
        Position=UDim2.new(0.5,-260,0.5,-200),
        BackgroundColor3=Theme.BgDark, BorderSizePixel=0,
        ClipsDescendants=true,
    }, self.Gui)
    AddCorner(self.Frame, 14)
    AddStroke(self.Frame, Theme.Border, 1)

    -- accent bar top
    self.AccentBar = Make("Frame",{
        Size=UDim2.new(1,0,0,3),BackgroundColor3=self.Accent,
        BorderSizePixel=0,ZIndex=20,
    }, self.Frame)
    AddCorner(self.AccentBar, 14)
