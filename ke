function CentingUI:AddTab(name)
    local tab = {Name=name, Elements={}}

    local btn = Make("TextButton",{
        Name=name,Size=UDim2.new(0,90,0,30),
        BackgroundColor3=Theme.BtnIdle,BorderSizePixel=0,
        Text=name,TextColor3=Theme.TextDim,TextSize=11,Font=FontMain,
        AutoButtonColor=false,ZIndex=6,
    }, self.TabScroll)
    AddCorner(btn, 7)

    btn.MouseEnter:Connect(function()
        if self.CurrentTab~=name then QT(btn,{BackgroundColor3=Theme.BtnHover},0.15):Play() end
    end)
    btn.MouseLeave:Connect(function()
        if self.CurrentTab~=name then QT(btn,{BackgroundColor3=Theme.BtnIdle},0.15):Play() end
    end)
    btn.MouseButton1Click:Connect(function() self:SelectTab(name) end)

    local container = Make("ScrollingFrame",{
        Name=name.."_Content",Size=UDim2.new(1,0,1,0),
        BackgroundTransparency=1,BorderSizePixel=0,
        ScrollBarThickness=3,ScrollBarImageColor3=self.Accent,ScrollBarImageTransparency=0.4,
        CanvasSize=UDim2.new(0,0,0,0),AutomaticCanvasSize=Enum.AutomaticSize.Y,
        Visible=false,ZIndex=2,
    }, self.ContentArea)
    Make("UIListLayout",{Padding=UDim.new(0,6),SortOrder=Enum.SortOrder.LayoutOrder}, container)
    Make("UIPadding",{PaddingTop=UDim.new(0,10),PaddingBottom=UDim.new(0,16),PaddingLeft=UDim.new(0,14),PaddingRight=UDim.new(0,14)}, container)

    tab.Button = btn
    tab.Container = container
    self.Tabs[name] = tab

    if not self.CurrentTab then self:SelectTab(name) end
    return name
end

function CentingUI:SelectTab(name)
    local tab = self.Tabs[name]
    if not tab then return end
    for n,t in pairs(self.Tabs) do
        t.Container.Visible = false
        QT(t.Button,{BackgroundColor3=Theme.BtnIdle,TextColor3=Theme.TextDim},0.2):Play()
    end
    tab.Container.Visible = true
    QT(tab.Button,{BackgroundColor3=self.Accent,TextColor3=Color3.fromRGB(8,8,14)},0.25):Play()
    self.CurrentTab = name
end

