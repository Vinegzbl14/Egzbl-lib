    -- title bar
    self.TitleBar = Make("Frame",{
        Name="TitleBar",Size=UDim2.new(1,0,0,42),
        BackgroundColor3=Theme.BgSurface,BorderSizePixel=0,ZIndex=5,
    }, self.Frame)
    AddCorner(self.TitleBar, 14)
    Make("Frame",{
        Size=UDim2.new(1,0,0,14),Position=UDim2.new(0,0,1,-14),
        BackgroundColor3=Theme.BgSurface,BorderSizePixel=0,ZIndex=4,
    }, self.TitleBar)

    -- dot
