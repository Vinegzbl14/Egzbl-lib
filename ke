function CentingUI:AddSlider(tabName, text, min, max, default, callback, suffix)
    local tab = self.Tabs[tabName]
    if not tab then return nil end
    min, max, default = min or 0, max or 100, default or 0
    suffix = suffix or ""
    local value = default

    local frame = Make("Frame",{Size=UDim2.new(1,0,0,58),BackgroundColor3=Theme.BgElement,BorderSizePixel=0}, tab.Container)
    AddCorner(frame, 8)

    Make("TextLabel",{
        Size=UDim2.new(0.65,0,0,20),Position=UDim2.new(0,14,0,6),
        BackgroundTransparency=1,Text=text or "Slider",
        TextColor3=Theme.TextMain,TextSize=12,Font=FontMain,TextXAlignment=Enum.TextXAlignment.Left,
    }, frame)

    local valLabel = Make("TextLabel",{
        Size=UDim2.new(0.3,0,0,20),Position=UDim2.new(1,-48,0,6),
        BackgroundTransparency=1,Text=tostring(default)..suffix,
        TextColor3=self.Accent,TextSize=12,Font=FontCode,TextXAlignment=Enum.TextXAlignment.Right,
    }, frame)

    local track = Make("Frame",{
        Size=UDim2.new(1,-28,0,6),Position=UDim2.new(0,14,0,36),
        BackgroundColor3=Theme.SliderTrack,BorderSizePixel=0,
    }, frame)
    AddCorner(track, 3)

    local fillPercent = (default-min)/(max-min)
    local fill = Make("Frame",{Size=UDim2.new(fillPercent,0,1,0),BackgroundColor3=self.Accent,BorderSizePixel=0}, track)
    AddCorner(fill, 3)

    local knob = Make("Frame",{
        Size=UDim2.new(0,14,0,14),Position=UDim2.new(fillPercent,-7,0.5,-7),
        BackgroundColor3=Theme.White,BorderSizePixel=0,ZIndex=5,
    }, track)
    AddCorner(knob, 7)

    local hitArea = Make("TextButton",{Size=UDim2.new(1,0,0,22),Position=UDim2.new(0,0,0,28),BackgroundTransparency=1,Text="",ZIndex=10}, frame)
    local sliding = false

    local function update(input)
        local relX = math.clamp((input.Position.X - track.AbsolutePosition.X) / track.AbsoluteSize.X, 0, 1)
        value = math.floor(min + (max-min)*relX + 0.5)
        fillPercent = (value-min)/(max-min)
        fill.Size = UDim2.new(fillPercent,0,1,0)
        knob.Position = UDim2.new(fillPercent,-7,0.5,-7)
        valLabel.Text = tostring(value)..suffix
        if callback then callback(value) end
    end

    hitArea.MouseButton1Down:Connect(function(input) sliding=true; update(input) end)
    UserInputService.InputChanged:Connect(function(input)
        if sliding and (input.UserInputType==Enum.UserInputType.MouseMovement or input.UserInputType==Enum.UserInputType.Touch) then update(input) end
    end)
    UserInputService.InputEnded:Connect(function(input)
        if input.UserInputType==Enum.UserInputType.MouseButton1 or input.UserInputType==Enum.UserInputType.Touch then sliding=false end
    end)

    return self:_AddElement(tabName,{Type="Slider",Instance=frame,SetValue=function(v)
        value=v; fillPercent=(v-min)/(max-min)
        fill.Size=UDim2.new(fillPercent,0,1,0); knob.Position=UDim2.new(fillPercent,-7,0.5,-7)
        valLabel.Text=tostring(v)..suffix
    end, GetValue=function() return value end})
end

