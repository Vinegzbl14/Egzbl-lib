local function Make(class, props, parent)
    local inst = Instance.new(class)
    for k,v in pairs(props or {}) do
        if k~="Parent" then inst[k]=v end
    end
    if parent then inst.Parent=parent end
    return inst
end

local function AddCorner(inst, r)
    return Make("UICorner",{CornerRadius=UDim.new(0,r or 8)},inst)
end

local function AddStroke(inst, c, t)
    return Make("UIStroke",{Color=c or Theme.Border,Thickness=t or 1,Transparency=0.5},inst)
end

local function QT(inst, props, dur, style, dir)
    return TweenService:Create(inst, TweenInfo.new(dur or 0.25, style or Enum.EasingStyle.Quint, dir or Enum.EasingDirection.Out), props)
end

local function LerpColor(c1,c2,t)
    return Color3.new(c1.R+(c2.R-c1.R)*t, c1.G+(c2.G-c1.G)*t, c1.B+(c2.B-c1.B)*t)
end

function CentingUI.new(opts)
    opts = opts or {}
    local self = setmetatable({}, CentingUI)
    self.Name = opts.Name or "Centing UI"
    self.Accent = opts.Accent or Color3.fromRGB(0,190,255)
    self.Tabs = {}
    self.CurrentTab = nil
    self.Notifications = {}
    self.IsMinimized = false
    self.IsOpen = true
    self:_Build()
    return self
end

