-- EGZBL FULL 10/10 UI LIBRARY

local Players = game:GetService("Players") local TweenService = game:GetService("TweenService") local RunService = game:GetService("RunService") local UserInputService = game:GetService("UserInputService")

local LocalPlayer = Players.LocalPlayer

local Library = {}

-- NOTIFICATION function Library:Notify(text) local Notif = Instance.new("TextLabel", game.CoreGui) Notif.Size = UDim2.new(0, 250, 0, 40) Notif.Position = UDim2.new(1, -260, 1, -60) Notif.BackgroundColor3 = Color3.fromRGB(20,20,20) Notif.TextColor3 = Color3.new(1,1,1) Notif.Text = text Notif.Font = Enum.Font.GothamBold Notif.TextSize = 14

task.delay(2, function()
    Notif:Destroy()
end)

end

-- CREATE WINDOW function Library:CreateWindow(title)

local ScreenGui = Instance.new("ScreenGui", LocalPlayer:WaitForChild("PlayerGui"))
ScreenGui.Name = "EGZBL_LIB"
ScreenGui.ResetOnSpawn = false

local MainFrame = Instance.new("Frame", ScreenGui)
MainFrame.Size = UDim2.new(0, 340, 0, 260)
MainFrame.Position = UDim2.new(0.35, 0, 0.35, 0)
MainFrame.BackgroundColor3 = Color3.fromRGB(20,20,20)
MainFrame.Active = true
MainFrame.Draggable = true

local function roundify(obj, radius)
    local c = Instance.new("UICorner")
    c.CornerRadius = UDim.new(0, radius or 8)
    c.Parent = obj
end

roundify(MainFrame,14)

-- RAINBOW SHADOW
local Shadow = Instance.new("Frame", MainFrame)
Shadow.Size = UDim2.new(1,12,1,12)
Shadow.Position = UDim2.new(0,6,0,6)
Shadow.BackgroundTransparency = 0.6
roundify(Shadow)

local hue = 0
RunService.RenderStepped:Connect(function()
    hue = (hue + 0.003) % 1
    Shadow.BackgroundColor3 = Color3.fromHSV(hue,1,1)
end)

-- TITLE
local Title = Instance.new("TextLabel", MainFrame)
Title.Size = UDim2.new(1,0,0,30)
Title.BackgroundColor3 = Color3.fromRGB(10,10,10)
Title.Text = title or "EGZBL HUB"
Title.TextColor3 = Color3.new(1,1,1)
Title.Font = Enum.Font.GothamBold
Title.TextSize = 16
roundify(Title,6)

-- KEYBIND
local visible = true
UserInputService.InputBegan:Connect(function(input, gpe)
    if gpe then return end
    if input.KeyCode == Enum.KeyCode.RightShift then
        visible = not visible
        MainFrame.Visible = visible
    end
end)

-- CONTENT
local Content = Instance.new("ScrollingFrame", MainFrame)
Content.Size = UDim2.new(1,0,1,-40)
Content.Position = UDim2.new(0,0,0,40)
Content.AutomaticCanvasSize = Enum.AutomaticSize.Y
Content.ScrollBarThickness = 4
Content.BackgroundColor3 = Color3.fromRGB(15,15,15)
roundify(Content,10)

local Layout = Instance.new("UIListLayout", Content)
Layout.Padding = UDim.new(0,8)

local Elements = {}

-- SECTION
function Elements:CreateSection(text)
    local lbl = Instance.new("TextLabel", Content)
    lbl.Size = UDim2.new(1,-10,0,20)
    lbl.Text = text
    lbl.BackgroundTransparency = 1
    lbl.TextColor3 = Color3.fromRGB(200,200,200)
    lbl.Font = Enum.Font.GothamBold
    lbl.TextSize = 14
end

-- BUTTON
function Elements:CreateButton(text, callback)
    local Btn = Instance.new("TextButton", Content)
    Btn.Size = UDim2.new(1,-10,0,32)
    Btn.Text = text
    Btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 13
    roundify(Btn,10)

    Btn.MouseButton1Click:Connect(function()
        if callback then callback() end
    end)
end

-- TOGGLE
function Elements:CreateToggle(text, default, callback)
    local state = default

    local Btn = Instance.new("TextButton", Content)
    Btn.Size = UDim2.new(1,-10,0,32)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 13
    Btn.TextColor3 = Color3.new(1,1,1)
    roundify(Btn,10)

    local function update()
        Btn.Text = text .. " : " .. (state and "ON" or "OFF")
        Btn.BackgroundColor3 = state and Color3.fromRGB(0,120,60) or Color3.fromRGB(40,40,40)
    end

    Btn.MouseButton1Click:Connect(function()
        state = not state
        update()
        if callback then callback(state) end
    end)

    update()
end

-- SLIDER
function Elements:CreateSlider(text, min, max, callback)
    local value = min

    local Btn = Instance.new("TextButton", Content)
    Btn.Size = UDim2.new(1,-10,0,32)
    Btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 13
    roundify(Btn,10)

    local function update()
        Btn.Text = text .. " : " .. value
    end

    Btn.MouseButton1Click:Connect(function()
        value = value + 1
        if value > max then value = min end
        update()
        if callback then callback(value) end
    end)

    update()
end

-- DROPDOWN
function Elements:CreateDropdown(text, list, callback)
    local index = 1

    local Btn = Instance.new("TextButton", Content)
    Btn.Size = UDim2.new(1,-10,0,32)
    Btn.BackgroundColor3 = Color3.fromRGB(40,40,40)
    Btn.TextColor3 = Color3.new(1,1,1)
    Btn.Font = Enum.Font.GothamBold
    Btn.TextSize = 13
    roundify(Btn,10)

    local function update()
        Btn.Text = text .. " : " .. list[index]
    end

    Btn.MouseButton1Click:Connect(function()
        index = index + 1
        if index > #list then index = 1 end
        update()
        if callback then callback(list[index]) end
    end)

    update()
end

return Elements

end

return Library

