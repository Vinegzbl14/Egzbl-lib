        function Tab:CreateSlider(cfg) cfg = cfg or {}
            local minVal, maxVal, increment, suffix = cfg.Min or 0, cfg.Max or 100, cfg.Increment or 1, cfg.Suffix or ""
            local currentVal = math.clamp(cfg.Default or minVal, minVal, maxVal)
            local callback = cfg.Callback or function() end
            local frame = Create("Frame", {Size = UDim2.new(1, -4, 0, 58), BackgroundColor3 = COLORS.ElementBG, ZIndex = 5, Parent = tabPage})
            AddCorner(frame, 8) AddStroke(frame, COLORS.Divider, 1, 0.6)
            Create("TextLabel", {Text = cfg.Name or "Slider", Font = FONT_SEMI, TextSize = 13, TextColor3 = COLORS.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 6), Size = UDim2.new(0.6, 0, 0, 18), ZIndex = 6, Parent = frame})
            local valLbl = Create("TextLabel", {Text = tostring(currentVal)..suffix, Font = FONT_SEMI, TextSize = 13, TextColor3 = COLORS.AccentBlue, TextXAlignment = Enum.TextXAlignment.Right, BackgroundTransparency = 1, Position = UDim2.new(0.6, 0, 0, 6), Size = UDim2.new(0.4, -14, 0, 18), ZIndex = 6, Parent = frame})
            local track = Create("Frame", {AnchorPoint = Vector2.new(0.5, 0), Position = UDim2.new(0.5, 0, 0, 34), Size = UDim2.new(1, -28, 0, 8), BackgroundColor3 = COLORS.SliderBG, ZIndex = 6, Parent = frame})
            AddCorner(track, 4)
            local initPct = (currentVal - minVal) / math.max(maxVal - minVal, 0.001)
            local fill = Create("Frame", {Size = UDim2.new(initPct, 0, 1, 0), BackgroundColor3 = Color3.new(1,1,1), ZIndex = 7, Parent = track})
            AddCorner(fill, 4) AddGradient(fill, COLORS.AccentRed, COLORS.AccentBlue, 0)
            local sKnob = Create("Frame", {AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(initPct, 0, 0.5, 0), Size = UDim2.new(0, 16, 0, 16), BackgroundColor3 = Color3.fromRGB(255,255,255), ZIndex = 9, Parent = track})
            AddCorner(sKnob, 999) AddStroke(sKnob, COLORS.AccentRed, 2, 0)
            local kGlow = Create("Frame", {AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0.5, 0, 0.5, 0), Size = UDim2.new(0, 24, 0, 24), BackgroundColor3 = COLORS.AccentRed, BackgroundTransparency = 0.8, ZIndex = 8, Parent = sKnob})
            AddCorner(kGlow, 999)
            local sliding = false
            local function snap(v) local s = math.floor(v/increment+0.5)*increment s = math.clamp(s,minVal,maxVal) if increment>=1 then s=math.floor(s+0.5) end return s end
            local function updSlider(input)
                local pct = math.clamp((input.Position.X - track.AbsolutePosition.X)/track.AbsoluteSize.X, 0, 1)
                local s = snap(minVal+(maxVal-minVal)*pct) currentVal = s local rp = (s-minVal)/math.max(maxVal-minVal,0.001)
                Tween(fill, {Size = UDim2.new(rp, 0, 1, 0)}, 0.06, Enum.EasingStyle.Linear) Tween(sKnob, {Position = UDim2.new(rp, 0, 0.5, 0)}, 0.06, Enum.EasingStyle.Linear) valLbl.Text = tostring(s)..suffix callback(s)
            end
            local iBtn = Create("TextButton", {Text = "", Size = UDim2.new(1, 12, 1, 16), AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0.5, 0, 0.5, 0), BackgroundTransparency = 1, ZIndex = 10, Parent = track})
            iBtn.InputBegan:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then sliding = true updSlider(i) end end)
            iBtn.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then sliding = false end end)
            UserInputService.InputChanged:Connect(function(i) if sliding and (i.UserInputType == Enum.UserInputType.MouseMovement or i.UserInputType == Enum.UserInputType.Touch) then updSlider(i) end end)
            UserInputService.InputEnded:Connect(function(i) if i.UserInputType == Enum.UserInputType.MouseButton1 or i.UserInputType == Enum.UserInputType.Touch then sliding = false end end)
            frame.MouseEnter:Connect(function() Tween(frame, {BackgroundColor3 = COLORS.ElementBGHover}, 0.15) Tween(kGlow, {BackgroundTransparency = 0.55, Size = UDim2.new(0, 30, 0, 30)}, 0.2) end)
            frame.MouseLeave:Connect(function() Tween(frame, {BackgroundColor3 = COLORS.ElementBG}, 0.15) Tween(kGlow, {BackgroundTransparency = 0.8, Size = UDim2.new(0, 24, 0, 24)}, 0.2) end)
            return {Set = function(_, v) currentVal = math.clamp(v,minVal,maxVal) local p=(currentVal-minVal)/math.max(maxVal-minVal,0.001) Tween(fill,{Size=UDim2.new(p,0,1,0)},0.2) Tween(sKnob,{Position=UDim2.new(p,0,0.5,0)},0.2) valLbl.Text=tostring(currentVal)..suffix callback(currentVal) end, Get = function() return currentVal end}
        end

