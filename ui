    local progressFill = Create("Frame", {Size = UDim2.new(0, 0, 1, 0), BackgroundColor3 = Color3.new(1,1,1), Parent = progressBG})
    AddCorner(progressFill, 4)
    AddGradient(progressFill, COLORS.AccentRed, COLORS.AccentBlue, 0)

    local dotsFrame = Create("Frame", {AnchorPoint = Vector2.new(0.5, 0), Position = UDim2.new(0.5, 0, 0, 175), Size = UDim2.new(0, 50, 0, 10), BackgroundTransparency = 1, Parent = loadFrame})
    local dots = {}
    for i = 1, 3 do
        dots[i] = Create("Frame", {AnchorPoint = Vector2.new(0.5, 0.5), Position = UDim2.new(0, (i-1)*20+5, 0.5, 0), Size = UDim2.new(0, 6, 0, 6), BackgroundColor3 = COLORS.AccentBlue, BackgroundTransparency = 0.6, Parent = dotsFrame})
        AddCorner(dots[i], 999)
    end

    task.spawn(function()
        while loadFrame and loadFrame.Parent do
            for i, dot in ipairs(dots) do
                Tween(dot, {BackgroundTransparency = 0, Size = UDim2.new(0, 9, 0, 9), BackgroundColor3 = COLORS.AccentRed}, 0.25)
                task.wait(0.12)
                Tween(dot, {BackgroundTransparency = 0.6, Size = UDim2.new(0, 6, 0, 6), BackgroundColor3 = COLORS.AccentBlue}, 0.25)
            end
            task.wait(0.3)
        end
    end)

    local statuses = {"Loading modules...", "Setting up UI...", "Preparing elements...", "Almost ready..."}
    task.spawn(function()
        for _, s in ipairs(statuses) do task.wait(0.6) if statusText and statusText.Parent then statusText.Text = s end end
    end)

    Tween(progressFill, {Size = UDim2.new(1, 0, 1, 0)}, 2.8, Enum.EasingStyle.Quad, Enum.EasingDirection.InOut)

    task.delay(3.2, function()
        if not loadFrame or not loadFrame.Parent then return end
        for _, v in pairs(loadFrame:GetDescendants()) do
            pcall(function()
                if v:IsA("TextLabel") then Tween(v, {TextTransparency = 1}, 0.4)
                elseif v:IsA("Frame") then Tween(v, {BackgroundTransparency = 1}, 0.4)
                elseif v:IsA("UIStroke") then Tween(v, {Transparency = 1}, 0.4) end
            end)
        end
        Tween(loadFrame, {BackgroundTransparency = 1}, 0.4)
        task.wait(0.5)
        if loadFrame and loadFrame.Parent then loadFrame:Destroy() end
        if onComplete then onComplete() end
    end)
end

