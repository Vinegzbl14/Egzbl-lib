    return Create("UIGradient", {Color = ColorSequence.new({ColorSequenceKeypoint.new(0, c1 or COLORS.AccentGradStart), ColorSequenceKeypoint.new(1, c2 or COLORS.AccentGradEnd)}), Rotation = rotation or 90, Parent = parent})
end

local function AddListLayout(parent, padding, dir, hAlign, vAlign, sortOrder)
