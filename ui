        function Tab:CreateColorPicker(cfg) cfg = cfg or {}
            local currentColor = cfg.Default or Color3.fromRGB(220,40,60) local opened = false local callback = cfg.Callback or function() end
            local frame = Create("Frame", {Size = UDim2.new(1, -4, 0, 42), BackgroundColor3 = COLORS.ElementBG, ClipsDescendants = true, ZIndex = 5, Parent = tabPage})
            AddCorner(frame, 8) AddStroke(frame, COLORS.Divider, 1, 0.6)
            local tBtn = Create("TextButton", {Text = "", Size = UDim2.new(1, 0, 0, 42), BackgroundTransparency = 1, ZIndex = 7, Parent = frame})
            Create("TextLabel", {Text = cfg.Name or "Color", Font = FONT_SEMI, TextSize = 13, TextColor3 = COLORS.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 0), Size = UDim2.new(0.6, 0, 0, 42), ZIndex = 8, Parent = frame})
            local prev = Create("Frame", {AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -14, 0, 21), Size = UDim2.new(0, 26, 0, 26), BackgroundColor3 = currentColor, ZIndex = 8, Parent = frame})
            AddCorner(prev, 6) AddStroke(prev, Color3.fromRGB(255,255,255), 2, 0.7)
            local rgbBox = Create("Frame", {Position = UDim2.new(0, 10, 0, 48), Size = UDim2.new(1, -20, 0, 88), BackgroundTransparency = 1, ZIndex = 8, Parent = frame})
            AddListLayout(rgbBox, 4)
            local function mkCS(ch, iv, col)
                local row = Create("Frame", {Size=UDim2.new(1,0,0,24), BackgroundTransparency=1, ZIndex=9, Parent=rgbBox})
                Create("TextLabel", {Text=ch, Font=FONT_BOLD, TextSize=11, TextColor3=col, BackgroundTransparency=1, Size=UDim2.new(0,14,1,0), ZIndex=10, Parent=row})
                local tBG = Create("Frame", {Position=UDim2.new(0,20,0.5,-4), Size=UDim2.new(1,-64,0,8), BackgroundColor3=COLORS.SliderBG, ZIndex=10, Parent=row})
                AddCorner(tBG, 4)
                local tF = Create("Frame", {Size=UDim2.new(iv/255,0,1,0), BackgroundColor3=col, ZIndex=11, Parent=tBG})
                AddCorner(tF, 4)
                local vL = Create("TextLabel", {Text=tostring(math.floor(iv)), Font=FONT_SEMI, TextSize=11, TextColor3=COLORS.SubText, TextXAlignment=Enum.TextXAlignment.Right, BackgroundTransparency=1, AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,0,0.5,0), Size=UDim2.new(0,34,1,0), ZIndex=10, Parent=row})
                local iA = Create("TextButton", {Text="", Size=UDim2.new(1,8,1,12), AnchorPoint=Vector2.new(0.5,0.5), Position=UDim2.new(0.5,0,0.5,0), BackgroundTransparency=1, ZIndex=12, Parent=tBG})
                local sl = false
                local function uc(input)
                    local p=math.clamp((input.Position.X-tBG.AbsolutePosition.X)/tBG.AbsoluteSize.X,0,1) local v=math.floor(p*255) tF.Size=UDim2.new(p,0,1,0) vL.Text=tostring(v)
                    local r,g,b=math.floor(currentColor.R*255),math.floor(currentColor.G*255),math.floor(currentColor.B*255)
                    if ch=="R" then r=v elseif ch=="G" then g=v else b=v end
                    currentColor=Color3.fromRGB(r,g,b) prev.BackgroundColor3=currentColor callback(currentColor)
                end
                iA.InputBegan:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sl=true uc(i) end end)
                iA.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sl=false end end)
                UserInputService.InputChanged:Connect(function(i) if sl and (i.UserInputType==Enum.UserInputType.MouseMovement or i.UserInputType==Enum.UserInputType.Touch) then uc(i) end end)
                UserInputService.InputEnded:Connect(function(i) if i.UserInputType==Enum.UserInputType.MouseButton1 or i.UserInputType==Enum.UserInputType.Touch then sl=false end end)
            end
            mkCS("R", currentColor.R*255, Color3.fromRGB(220,60,60))
            mkCS("G", currentColor.G*255, Color3.fromRGB(60,220,80))
            mkCS("B", currentColor.B*255, Color3.fromRGB(60,100,220))
            tBtn.MouseButton1Click:Connect(function() opened=not opened if opened then Tween(frame,{Size=UDim2.new(1,-4,0,148)},0.3,Enum.EasingStyle.Back) else Tween(frame,{Size=UDim2.new(1,-4,0,42)},0.25) end end)
            tBtn.MouseEnter:Connect(function() Tween(frame,{BackgroundColor3=COLORS.ElementBGHover},0.15) end)
            tBtn.MouseLeave:Connect(function() Tween(frame,{BackgroundColor3=COLORS.ElementBG},0.15) end)
            return {Set=function(_,c) currentColor=c prev.BackgroundColor3=c callback(c) end, Get=function() return currentColor end}
        end

        return Tab
    end

    function Window:Destroy()
        Tween(mainFrame, {Size = UDim2.new(0, W, 0, 0), BackgroundTransparency = 1}, 0.4)
        task.delay(0.45, function() screenGui:Destroy() end)
    end

    ShowLoadingScreen(screenGui, loadTitle, loadSub, function()
        mainFrame.Visible = true
        mainFrame.BackgroundTransparency = 0
        Tween(mainFrame, {Size = UDim2.new(0, W, 0, H)}, 0.5, Enum.EasingStyle.Back)
    end)

    return Window
end

function Centing:Notify(cfg) cfg = cfg or {}
    local title,content,duration,nType = cfg.Title or "Notification", cfg.Content or "", cfg.Duration or 4, cfg.Type or "Info"
    local tc = {Info=COLORS.AccentBlue, Warning=Color3.fromRGB(255,180,40), Error=COLORS.AccentRed, Success=Color3.fromRGB(40,200,120)}
    local accent = tc[nType] or COLORS.AccentBlue
    local icons = {Info="ℹ", Warning="⚠", Error="✕", Success="✓"}
    local icon = icons[nType] or "ℹ"
    local nGui = CoreGui:FindFirstChild("CentingUI_Notifs")
    if not nGui then
        nGui = Create("ScreenGui", {Name="CentingUI_Notifs", ZIndexBehavior=Enum.ZIndexBehavior.Sibling, ResetOnSpawn=false, IgnoreGuiInset=true})
        pcall(function() nGui.Parent=CoreGui end) if not nGui.Parent then nGui.Parent=LocalPlayer:WaitForChild("PlayerGui") end
        local cont = Create("Frame", {Name="Container", AnchorPoint=Vector2.new(1,1), Position=UDim2.new(1,-16,1,-16), Size=UDim2.new(0,IS_MOBILE and 260 or 300,1,-32), BackgroundTransparency=1, Parent=nGui})
        AddListLayout(cont, 8, Enum.FillDirection.Vertical, Enum.HorizontalAlignment.Right, Enum.VerticalAlignment.Bottom)
    end
    local cont = nGui:FindFirstChild("Container")
    local nF = Create("Frame", {Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, BackgroundColor3=COLORS.Background, BackgroundTransparency=1, ClipsDescendants=true, Parent=cont})
    AddCorner(nF, 10) AddStroke(nF, accent, 1, 0.3) AddPadding(nF, 10, 12, 12, 12)
    local nL = AddListLayout(nF, 4) nL.HorizontalAlignment = Enum.HorizontalAlignment.Left
    Create("Frame", {Size=UDim2.new(1,24,0,2), Position=UDim2.new(0,-12,0,-10), BackgroundColor3=accent, BorderSizePixel=0, ZIndex=2, Parent=nF})
    local tR = Create("Frame", {Size=UDim2.new(1,0,0,18), BackgroundTransparency=1, Parent=nF})
    Create("TextLabel", {Text=icon, Font=FONT_BOLD, TextSize=14, TextColor3=accent, BackgroundTransparency=1, Size=UDim2.new(0,18,1,0), Parent=tR})
    Create("TextLabel", {Text=" "..title, Font=FONT_BOLD, TextSize=14, TextColor3=COLORS.Text, TextXAlignment=Enum.TextXAlignment.Left, BackgroundTransparency=1, Position=UDim2.new(0,20,0,0), Size=UDim2.new(1,-20,1,0), Parent=tR})
    if content ~= "" then Create("TextLabel", {Text=content, Font=FONT_REG, TextSize=12, TextColor3=COLORS.SubText, TextXAlignment=Enum.TextXAlignment.Left, TextWrapped=true, BackgroundTransparency=1, Size=UDim2.new(1,0,0,0), AutomaticSize=Enum.AutomaticSize.Y, Parent=nF}) end
    local pBG = Create("Frame", {Size=UDim2.new(1,0,0,3), BackgroundColor3=COLORS.SliderBG, Parent=nF}) AddCorner(pBG, 2)
    local pFl = Create("Frame", {Size=UDim2.new(1,0,1,0), BackgroundColor3=accent, Parent=pBG}) AddCorner(pFl, 2)
    task.wait() Tween(nF, {BackgroundTransparency=0.05}, 0.3) Tween(pFl, {Size=UDim2.new(0,0,1,0)}, duration, Enum.EasingStyle.Linear)
    task.delay(duration, function()
        if not nF or not nF.Parent then return end
        for _,v in pairs(nF:GetDescendants()) do pcall(function() if v:IsA("TextLabel") then Tween(v,{TextTransparency=1},0.35) elseif v:IsA("Frame") then Tween(v,{BackgroundTransparency=1},0.35) elseif v:IsA("UIStroke") then Tween(v,{Transparency=1},0.35) end end) end
        Tween(nF, {BackgroundTransparency=1}, 0.35) task.wait(0.4) if nF and nF.Parent then nF:Destroy() end
    end)
end

return Centing