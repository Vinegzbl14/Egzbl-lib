        function Tab:CreateDropdown(cfg) cfg = cfg or {}
            local options = cfg.Options or {} local multi = cfg.MultiSelect or false local callback = cfg.Callback or function() end
            local selected = multi and {} or (cfg.Default or (options[1] or "")) local opened = false
            if multi and type(cfg.Default)=="table" then for _,v in pairs(cfg.Default) do selected[v]=true end end
            local frame = Create("Frame", {Size = UDim2.new(1, -4, 0, 42), BackgroundColor3 = COLORS.ElementBG, ClipsDescendants = true, ZIndex = 5, Parent = tabPage})
            AddCorner(frame, 8) AddStroke(frame, COLORS.Divider, 1, 0.6)
            local topBtn = Create("TextButton", {Text = "", Size = UDim2.new(1, 0, 0, 42), BackgroundTransparency = 1, ZIndex = 7, Parent = frame})
            Create("TextLabel", {Text = cfg.Name or "Dropdown", Font = FONT_SEMI, TextSize = 13, TextColor3 = COLORS.Text, TextXAlignment = Enum.TextXAlignment.Left, BackgroundTransparency = 1, Position = UDim2.new(0, 14, 0, 0), Size = UDim2.new(0.45, 0, 0, 42), ZIndex = 8, Parent = frame})
            local function gst() if multi then local n={} for k,_ in pairs(selected) do table.insert(n,k) end return #n>0 and table.concat(n,", ") or "None" else return tostring(selected) end end
            local selLbl = Create("TextLabel", {Text = gst(), Font = FONT_REG, TextSize = 12, TextColor3 = COLORS.SubText, TextXAlignment = Enum.TextXAlignment.Right, TextTruncate = Enum.TextTruncate.AtEnd, BackgroundTransparency = 1, Position = UDim2.new(0.4, 0, 0, 0), Size = UDim2.new(0.6, -42, 0, 42), ZIndex = 8, Parent = frame})
            local arw = Create("TextLabel", {Text = "▾", Font = FONT_BOLD, TextSize = 16, TextColor3 = COLORS.SubText, BackgroundTransparency = 1, AnchorPoint = Vector2.new(1, 0.5), Position = UDim2.new(1, -14, 0, 21), Size = UDim2.new(0, 16, 0, 16), ZIndex = 8, Parent = frame})
            local optC = Create("Frame", {Position = UDim2.new(0, 8, 0, 46), Size = UDim2.new(1, -16, 0, 0), BackgroundTransparency = 1, ZIndex = 8, Parent = frame})
            local oL = AddListLayout(optC, 3)
            oL:GetPropertyChangedSignal("AbsoluteContentSize"):Connect(function() optC.Size = UDim2.new(1, -16, 0, oL.AbsoluteContentSize.Y) end)
            local function bld()
                for _,c in pairs(optC:GetChildren()) do if c:IsA("TextButton") then c:Destroy() end end
                for _,opt in ipairs(options) do
                    local act = multi and selected[opt] or (selected==opt)
                    local ob = Create("TextButton", {Text="", Size=UDim2.new(1,0,0,30), BackgroundColor3=act and COLORS.DropdownItemHover or COLORS.DropdownItem, AutoButtonColor=false, ZIndex=9, Parent=optC})
                    AddCorner(ob, 6)
                    Create("TextLabel", {Text=opt, Font=FONT_REG, TextSize=13, TextColor3=act and COLORS.Text or COLORS.SubText, TextXAlignment=Enum.TextXAlignment.Left, BackgroundTransparency=1, Position=UDim2.new(0,10,0,0), Size=UDim2.new(1,-36,1,0), ZIndex=10, Parent=ob})
                    Create("TextLabel", {Text=act and "●" or "○", Font=FONT_BOLD, TextSize=12, TextColor3=act and COLORS.AccentRed or COLORS.DimText, BackgroundTransparency=1, AnchorPoint=Vector2.new(1,0.5), Position=UDim2.new(1,-8,0.5,0), Size=UDim2.new(0,16,0,16), ZIndex=10, Parent=ob})
                    ob.MouseEnter:Connect(function() Tween(ob,{BackgroundColor3=COLORS.DropdownItemHover},0.12) end)
                    ob.MouseLeave:Connect(function() local a=multi and selected[opt] or (selected==opt) Tween(ob,{BackgroundColor3=a and COLORS.DropdownItemHover or COLORS.DropdownItem},0.12) end)
                    ob.MouseButton1Click:Connect(function()
                        if multi then selected[opt]=not selected[opt] or nil if not selected[opt] then selected[opt]=nil end else selected=opt end
                        selLbl.Text=gst() bld() callback(selected)
                        if not multi then opened=false Tween(frame,{Size=UDim2.new(1,-4,0,42)},0.25) Tween(arw,{Rotation=0},0.25) end
                    end)
                end
            end
            bld()
            topBtn.MouseButton1Click:Connect(function()
                opened=not opened
                if opened then bld() task.wait() Tween(frame,{Size=UDim2.new(1,-4,0,50+optC.Size.Y.Offset+8)},0.3,Enum.EasingStyle.Back) Tween(arw,{Rotation=180},0.3)
                else Tween(frame,{Size=UDim2.new(1,-4,0,42)},0.25) Tween(arw,{Rotation=0},0.25) end
            end)
            topBtn.MouseEnter:Connect(function() Tween(frame,{BackgroundColor3=COLORS.ElementBGHover},0.15) end)
            topBtn.MouseLeave:Connect(function() Tween(frame,{BackgroundColor3=COLORS.ElementBG},0.15) end)
            return {Set=function(_,v) selected=v selLbl.Text=gst() bld() callback(selected) end, Refresh=function(_,nO,nD) options=nO or options if nD then selected=nD end selLbl.Text=gst() bld() end, Get=function() return selected end}
        end

